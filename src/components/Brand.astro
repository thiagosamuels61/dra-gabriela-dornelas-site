---
import emblem from "../icons/emblem.svg?raw";

interface Props {
  variant?: "header" | "footer";
  href?: string;
}
const { variant = "header", href = "#inicio" } = Astro.props;
---

<a class={`brand brand--${variant}`} href={href} aria-label="Dra. Gabriela Dornelas — Ginecologia Íntima, início">
  <span class="brand__mark" set:html={emblem} />
  <span class="brand__text">
    <span class="brand__name">Dra. Gabriela Dornelas</span>
    <span class="brand__sub">Ginecologia Íntima</span>
  </span>
</a>

<style>
  .brand {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    text-decoration: none;
    color: inherit;
  }
  .brand__mark {
    display: block;
    width: 44px;
    height: 44px;
    flex: none;
  }
  .brand__mark :global(svg) {
    width: 100%;
    height: 100%;
    display: block;
  }
  .brand__text {
    display: flex;
    flex-direction: column;
    line-height: 1.05;
  }
  .brand__name {
    font-family: var(--font-title);
    font-size: 1.18rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    color: var(--color-primary);
  }
  .brand__sub {
    font-family: var(--font-logo);
    font-size: 0.56rem;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--color-gold);
    margin-top: 3px;
  }
  .brand--footer .brand__name {
    color: var(--color-white);
  }
  .brand--footer .brand__sub {
    color: var(--color-gold-soft);
  }
  @media (max-width: 600px) {
    .brand__mark {
      width: 38px;
      height: 38px;
    }
    .brand__name {
      font-size: 1.02rem;
    }
  }
</style>
