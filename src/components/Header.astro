---
import { content } from "../data/content.ts";
import Brand from "./Brand.astro";
const { nav, hero, doctor } = content;
---

<header class="header" data-header>
  <div class="container header__inner">
    <Brand variant="header" />

    <nav class="nav" id="nav" data-nav aria-label="Navegação principal">
      <ul>
        {nav.map((item) => (
          <li><a href={item.href}>{item.label}</a></li>
        ))}
      </ul>
      <a class="btn btn-primary nav__cta-mobile" href={doctor.whatsappUrl} target="_blank" rel="noopener">
        {hero.ctaLabel}
      </a>
    </nav>

    <div class="header__actions">
      <a class="btn btn-primary header__cta" href={doctor.whatsappUrl} target="_blank" rel="noopener">
        {hero.ctaLabel}
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
      </a>
      <button class="nav-toggle" data-nav-toggle aria-label="Abrir menu" aria-expanded="false" aria-controls="nav">
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>
</header>

<style>
  .header {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 100;
    padding: 9px 0;
    background: rgba(247, 242, 238, 0.9);
    backdrop-filter: blur(14px);
    border-bottom: 1px solid rgba(184, 135, 83, 0.14);
    transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1),
      background 0.4s ease, box-shadow 0.4s ease, padding 0.4s ease;
    will-change: transform;
  }
  .header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
  }
  .header.is-scrolled {
    background: rgba(247, 242, 238, 0.95);
    box-shadow: 0 8px 30px rgba(26, 13, 14, 0.08);
    padding: 7px 0;
  }
  /* esconde ao rolar para baixo, reaparece ao subir */
  .header.is-hidden {
    transform: translateY(-105%);
  }

  .nav ul {
    display: flex;
    align-items: center;
    gap: 26px;
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .nav a {
    font-family: var(--font-body);
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: 0.01em;
    color: var(--color-brown);
    text-decoration: none;
    position: relative;
    padding: 4px 0;
    transition: color var(--transition);
  }
  .nav a::after {
    content: "";
    position: absolute;
    left: 0;
    bottom: -2px;
    width: 0;
    height: 1px;
    background: var(--color-gold);
    transition: width var(--transition);
  }
  .nav a:hover {
    color: var(--color-primary);
  }
  .nav a:hover::after {
    width: 100%;
  }
  .nav__cta-mobile {
    display: none;
  }

  .header__actions {
    display: flex;
    align-items: center;
    gap: 14px;
  }
  .header__cta {
    min-height: 46px;
    padding: 0 22px;
    font-size: 0.78rem;
  }

  .nav-toggle {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 44px;
    height: 44px;
    background: transparent;
    border: none;
    cursor: pointer;
    padding: 10px;
  }
  .nav-toggle span {
    display: block;
    height: 2px;
    width: 100%;
    background: var(--color-primary);
    border-radius: 2px;
    transition: transform 0.3s ease, opacity 0.3s ease;
  }

  /* ---------- Responsivo ---------- */
  @media (max-width: 1180px) {
    .nav ul {
      gap: 16px;
    }
    .nav a {
      font-size: 0.76rem;
    }
    .header__cta {
      padding: 0 18px;
    }
  }

  @media (max-width: 1080px) {
    .header__cta {
      display: none;
    }
    .nav-toggle {
      display: flex;
    }
    .nav {
      position: fixed;
      inset: 0 0 0 auto;
      width: min(84vw, 360px);
      height: 100dvh;
      background: var(--color-bg-soft);
      box-shadow: -20px 0 60px rgba(26, 13, 14, 0.18);
      flex-direction: column;
      justify-content: flex-start;
      gap: 28px;
      padding: 96px 40px 40px;
      overflow-y: auto;
      visibility: hidden;
      transform: translateX(100%);
      transition: transform 0.4s var(--ease-out), visibility 0s linear 0.4s;
    }
    .nav ul {
      flex-direction: column;
      align-items: flex-start;
      gap: 20px;
    }
    .nav a {
      font-size: 1.08rem;
    }
    .nav__cta-mobile {
      display: inline-flex;
    }
    /* botão do menu mobile: largura total + texto claro (vence .nav a) */
    .nav a.nav__cta-mobile {
      width: 100%;
      margin-top: 8px;
      color: var(--color-white);
    }
    .nav a.nav__cta-mobile:hover {
      color: var(--color-primary-dark);
    }
    .header.nav-open .nav {
      transform: translateX(0);
      visibility: visible;
      transition: transform 0.4s var(--ease-out), visibility 0s;
    }
    .header.nav-open .nav-toggle span:nth-child(1) {
      transform: translateY(7px) rotate(45deg);
    }
    .header.nav-open .nav-toggle span:nth-child(2) {
      opacity: 0;
    }
    .header.nav-open .nav-toggle span:nth-child(3) {
      transform: translateY(-7px) rotate(-45deg);
    }
  }

  :global(body.no-scroll) {
    overflow: hidden;
  }
</style>
