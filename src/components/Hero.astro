---
import { content } from "../data/content.ts";
import Icon from "./Icon.astro";
const { hero, doctor } = content;
const [line1, line2, line3] = hero.titleLines;
---

<section id="inicio" class="hero" data-hero data-parallax-scope>
  <img
    class="hero__bg"
    src="/hero-gabriela.webp"
    width="1920"
    height="900"
    alt="Dra. Gabriela Dornelas"
    fetchpriority="high"
    decoding="async"
  />

  <div class="container hero__inner">
    <div class="hero__content">
      <h1 class="hero__title">
        <span class="hero__line">{line1}<Icon name="sparkle" class="hero__sparkle" /></span>
        <span class="hero__line">{line2}</span>
        <span class="hero__line accent">{line3}</span>
      </h1>

      <p class="hero__sub" data-hero-in>
        {hero.subtitlePre}<strong>{hero.subtitleStrong}</strong>
      </p>

      <div class="hero__services" data-hero-in>
        {hero.services.map((s, i) => (
          <>
            {i > 0 && <span class="hero__divider" aria-hidden="true"></span>}
            <div class="hero__service">
              <span class="service-icon"><Icon name={s.key} /></span>
              <span class="hero__service-label">{s.label}</span>
            </div>
          </>
        ))}
      </div>

      <div class="hero__actions" data-hero-in>
        <a class="btn btn-primary" href={doctor.whatsappUrl} target="_blank" rel="noopener">
          {hero.ctaLabel}
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
        </a>
        <p class="hero__location">
          {hero.locationPre}<br /><strong>{hero.locationStrong}</strong>
        </p>
      </div>
    </div>
  </div>

  <div class="hero__crm">
    <div class="container hero__crm-inner">
      <span class="hero__crm-mark"><Icon name="sparkle" /></span>
      <span class="hero__crm-item">{doctor.crm}</span>
      <span class="hero__crm-sep" aria-hidden="true"></span>
      <span class="hero__crm-item">{doctor.rqe}</span>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: calc(clamp(660px, 94vh, 940px) + 40px);
    background: var(--color-cream);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  .hero__bg {
    position: absolute;
    top: 65px; /* grudado logo abaixo do menu (altura exata do header) */
    left: 0;
    width: 100%;
    height: calc(100% - 65px);
    object-fit: cover;
    object-position: right top;
    z-index: 0;
  }

  .hero__inner {
    position: relative;
    z-index: 2;
    flex: 1;
    display: flex;
    align-items: center;
    padding-top: 168px;
    padding-bottom: 116px;
  }
  .hero__content {
    max-width: 600px;
  }

  .hero__title {
    color: var(--color-brown);
    font-size: clamp(2.9rem, 4.8vw, 5rem);
    line-height: 0.98;
  }
  .hero__line {
    display: block;
  }
  .hero__title .accent {
    color: var(--color-primary);
  }
  .hero :global(.hero__sparkle) {
    width: 0.36em;
    height: 0.36em;
    color: var(--color-gold);
    vertical-align: 0.55em;
    margin-left: 0.14em;
  }

  .hero__sub {
    max-width: 460px;
    margin-top: 26px;
    font-size: 1.12rem;
    color: var(--color-brown);
  }
  .hero__sub strong {
    color: var(--color-primary);
    font-weight: 700;
  }

  .hero__services {
    display: flex;
    align-items: flex-start;
    gap: 18px;
    margin-top: 38px;
  }
  .hero__service {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 12px;
    width: 104px;
  }
  .hero__service-label {
    font-family: var(--font-title);
    font-size: 1.02rem;
    font-weight: 600;
    line-height: 1.1;
    color: var(--color-text);
    letter-spacing: -0.01em;
  }
  .hero__divider {
    width: 1px;
    align-self: stretch;
    margin: 6px 0 30px;
    background: linear-gradient(
      180deg,
      transparent,
      rgba(81, 9, 10, 0.22),
      transparent
    );
  }

  .hero__actions {
    display: flex;
    align-items: center;
    gap: 28px;
    margin-top: 40px;
    flex-wrap: wrap;
  }
  .hero__location {
    font-size: 0.95rem;
    line-height: 1.45;
    color: var(--color-text-muted);
  }
  .hero__location strong {
    color: var(--color-primary);
    font-weight: 700;
  }

  /* ---------- CRM bar (referencia2 bottom) ---------- */
  .hero__crm {
    position: relative;
    z-index: 3;
    background: var(--color-primary);
    color: var(--color-white);
    min-height: 64px;
    display: flex;
    align-items: center;
  }
  .hero__crm-inner {
    display: flex;
    align-items: center;
    gap: 18px;
  }
  .hero__crm-mark {
    width: 30px;
    height: 30px;
    border: 1px solid rgba(255, 255, 255, 0.4);
    border-radius: 50%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--color-champagne);
  }
  .hero__crm-mark :global(svg) {
    width: 15px;
    height: 15px;
  }
  .hero__crm-item {
    font-size: 0.88rem;
    letter-spacing: 0.06em;
    font-weight: 500;
  }
  .hero__crm-sep {
    width: 1px;
    height: 18px;
    background: rgba(255, 255, 255, 0.32);
  }

  /* ---------- Responsivo ---------- */
  @media (max-width: 980px) {
    .hero {
      min-height: 0;
      padding-top: 63px;
    }
    .hero__bg {
      position: relative;
      top: auto;
      width: 100%;
      height: 50vh;
      min-height: 350px;
      object-position: 88% 16%;
    }
    .hero__inner {
      display: block;
      padding: 44px 0 56px;
      background: var(--color-cream);
    }
    .hero__content {
      max-width: 560px;
      margin: 0 auto;
      text-align: center;
    }
    .hero__title {
      font-size: clamp(2.65rem, 9.5vw, 3.5rem);
    }
    .hero__sub {
      margin-left: auto;
      margin-right: auto;
    }
    .hero__services {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 26px 0;
      max-width: 360px;
      margin-left: auto;
      margin-right: auto;
    }
    .hero__service {
      width: auto;
    }
    .hero__divider {
      display: none;
    }
    .hero__actions {
      justify-content: center;
    }
  }

  @media (max-width: 520px) {
    .hero__location {
      width: 100%;
      text-align: center;
    }
  }
</style>
