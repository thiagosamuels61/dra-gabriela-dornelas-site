---
import { content } from "../data/content.ts";
import Icon from "./Icon.astro";
const { hero, doctor } = content;
const [line1, line2, line3] = hero.titleLines;
---

<section id="inicio" class="hero" data-hero data-parallax-scope>
  <img
    class="hero__bg"
    src="/hero-gabriela.webp"
    width="1920"
    height="900"
    alt="Dra. Gabriela Dornelas"
    fetchpriority="high"
    decoding="async"
  />

  <div class="container hero__inner">
    <div class="hero__content">
      <h1 class="hero__title">
        <span class="hero__line">{line1}<Icon name="sparkle" class="hero__sparkle" /></span>
        <span class="hero__line">{line2}</span>
        <span class="hero__line accent">{line3}</span>
      </h1>

      <p class="hero__sub" data-hero-in>
        {hero.subtitlePre}<strong>{hero.subtitleStrong}</strong>
      </p>

      <div class="hero__services" data-hero-in>
        {hero.services.map((s, i) => (
          <>
            {i > 0 && <span class="hero__divider" aria-hidden="true"></span>}
            <div class="hero__service">
              <span class="service-icon"><Icon name={s.key} /></span>
              <span class="hero__service-label">{s.label}</span>
            </div>
          </>
        ))}
      </div>

      <div class="hero__actions" data-hero-in>
        <a class="btn btn-primary" href={doctor.whatsappUrl} target="_blank" rel="noopener">
          {hero.ctaLabel}
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
        </a>
        <p class="hero__location">
          {hero.locationPre}<br /><strong>{hero.locationStrong}</strong>
        </p>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    background: var(--color-cream);
    padding-top: 65px; /* abre espaço para o header fixo sem colapso de margem */
  }
  /* imagem por inteiro (proporção natural), logo abaixo do header fixo */
  .hero__bg {
    display: block;
    width: 100%;
    height: auto;
  }

  .hero__inner {
    position: absolute;
    top: 65px;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 2;
    display: flex;
    align-items: center;
  }
  .hero__content {
    max-width: 560px;
  }

  .hero__title {
    color: var(--color-brown);
    font-size: clamp(2.6rem, 4.4vw, 4.6rem);
    line-height: 0.98;
  }
  .hero__line {
    display: block;
  }
  .hero__title .accent {
    color: var(--color-primary);
  }
  .hero :global(.hero__sparkle) {
    width: 0.36em;
    height: 0.36em;
    color: var(--color-gold);
    vertical-align: 0.55em;
    margin-left: 0.14em;
  }

  .hero__sub {
    max-width: 440px;
    margin-top: 22px;
    font-size: 1.08rem;
    color: var(--color-brown);
  }
  .hero__sub strong {
    color: var(--color-primary);
    font-weight: 700;
  }

  .hero__services {
    display: flex;
    align-items: flex-start;
    gap: 16px;
    margin-top: 30px;
  }
  .hero__service {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 10px;
    width: 100px;
  }
  .hero__service-label {
    font-family: var(--font-title);
    font-size: 1rem;
    font-weight: 600;
    line-height: 1.1;
    color: var(--color-text);
    letter-spacing: -0.01em;
  }
  .hero__divider {
    width: 1px;
    align-self: stretch;
    margin: 6px 0 28px;
    background: linear-gradient(
      180deg,
      transparent,
      rgba(81, 9, 10, 0.22),
      transparent
    );
  }

  .hero__actions {
    display: flex;
    align-items: center;
    gap: 26px;
    margin-top: 32px;
    flex-wrap: wrap;
  }
  .hero__location {
    font-size: 0.95rem;
    line-height: 1.45;
    color: var(--color-text-muted);
  }
  .hero__location strong {
    color: var(--color-primary);
    font-weight: 700;
  }

  /* ---------- Responsivo ---------- */
  /* abaixo de telas largas, layout empilhado (imagem em cima, texto embaixo)
     para o conteúdo nunca espremer sobre a imagem */
  @media (max-width: 1180px) {
    .hero {
      padding-top: 63px;
    }
    .hero__bg {
      width: 100%;
      height: 50vh;
      min-height: 350px;
      margin-top: 0;
      object-fit: cover;
      object-position: 88% 16%;
    }
    .hero__inner {
      position: static;
      display: block;
      padding: 44px 0 56px;
      background: var(--color-cream);
    }
    .hero__content {
      max-width: 560px;
      margin: 0 auto;
      text-align: center;
    }
    .hero__title {
      font-size: clamp(2.65rem, 9.5vw, 3.5rem);
    }
    .hero__sub {
      margin-left: auto;
      margin-right: auto;
    }
    .hero__services {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 26px 0;
      max-width: 360px;
      margin-left: auto;
      margin-right: auto;
    }
    .hero__service {
      width: auto;
    }
    .hero__divider {
      display: none;
    }
    .hero__actions {
      justify-content: center;
    }
  }

  @media (max-width: 520px) {
    .hero__location {
      width: 100%;
      text-align: center;
    }
  }
</style>
