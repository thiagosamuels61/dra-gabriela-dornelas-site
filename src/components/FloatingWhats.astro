---
import { content } from "../data/content.ts";
const { doctor } = content;
---

<a
  class="whats-float"
  href={doctor.whatsappUrl}
  target="_blank"
  rel="noopener"
  aria-label="Agendar pelo WhatsApp"
>
  <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
    <path d="M12.04 2C6.58 2 2.13 6.45 2.13 11.91c0 1.75.46 3.46 1.32 4.97L2 22l5.25-1.38a9.9 9.9 0 0 0 4.79 1.22h.01c5.46 0 9.91-4.45 9.91-9.91 0-2.65-1.03-5.14-2.9-7.01A9.82 9.82 0 0 0 12.04 2Zm0 1.8c2.17 0 4.21.85 5.75 2.38a8.06 8.06 0 0 1 2.38 5.74c0 4.48-3.65 8.12-8.12 8.12a8.1 8.1 0 0 1-4.13-1.13l-.3-.18-3.12.82.83-3.04-.19-.31a8.06 8.06 0 0 1-1.24-4.3c0-4.47 3.64-8.11 8.11-8.11Zm-3.7 4.46c-.18 0-.46.07-.7.33-.24.26-.92.9-.92 2.18 0 1.28.94 2.52 1.07 2.7.13.17 1.83 2.8 4.5 3.92.63.27 1.12.43 1.5.55.63.2 1.2.17 1.66.1.5-.07 1.56-.64 1.78-1.25.22-.62.22-1.14.16-1.25-.07-.11-.24-.18-.5-.31-.26-.13-1.56-.77-1.8-.86-.24-.09-.42-.13-.6.13-.17.26-.68.86-.84 1.04-.15.18-.31.2-.57.07-.26-.13-1.11-.41-2.11-1.3-.78-.7-1.31-1.56-1.46-1.82-.16-.26-.02-.4.11-.53.12-.12.26-.31.4-.46.13-.16.17-.27.26-.45.09-.18.04-.33-.02-.46-.07-.13-.6-1.44-.82-1.97-.21-.51-.43-.44-.6-.45h-.5Z"/>
  </svg>
  <span class="whats-float__pulse" aria-hidden="true"></span>
</a>

<style>
  .whats-float {
    position: fixed;
    right: 24px;
    bottom: 24px;
    width: 58px;
    height: 58px;
    border-radius: 50%;
    display: grid;
    place-items: center;
    background: #25d366;
    color: #fff;
    box-shadow: 0 12px 30px rgba(37, 211, 102, 0.42);
    z-index: 95;
    transition: transform 0.3s var(--ease-out), box-shadow 0.3s ease;
  }
  .whats-float svg {
    width: 32px;
    height: 32px;
    position: relative;
    z-index: 2;
  }
  .whats-float:hover {
    transform: translateY(-3px) scale(1.05);
    box-shadow: 0 16px 38px rgba(37, 211, 102, 0.5);
  }
  .whats-float__pulse {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    background: #25d366;
    z-index: 1;
    animation: whats-pulse 2.4s ease-out infinite;
  }
  @keyframes whats-pulse {
    0% {
      transform: scale(1);
      opacity: 0.6;
    }
    70%,
    100% {
      transform: scale(1.8);
      opacity: 0;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .whats-float__pulse {
      animation: none;
      display: none;
    }
  }
  @media (max-width: 560px) {
    .whats-float {
      width: 52px;
      height: 52px;
    }
  }
</style>
