---
import { content } from "../data/content.ts";
const { premiumCta, doctor } = content;
---

<section class="premium" data-parallax-scope>
  <div class="premium__glow" data-parallax="0.18" aria-hidden="true"></div>
  <span class="premium__mono" aria-hidden="true">G</span>
  <div class="container premium__inner">
    <span class="kicker kicker--center" data-reveal>{doctor.role}</span>
    <h2 data-reveal data-reveal-delay="1">{premiumCta.title}</h2>
    <p data-reveal data-reveal-delay="2">{premiumCta.text}</p>
    <div class="premium__actions" data-reveal data-reveal-delay="3">
      <a class="btn btn-gold" href={doctor.whatsappUrl} target="_blank" rel="noopener">
        {premiumCta.ctaLabel}
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
      </a>
      <a class="btn btn-ghost-light" href={doctor.instagramUrl} target="_blank" rel="noopener">
        {doctor.instagram}
      </a>
    </div>
  </div>
</section>

<style>
  .premium {
    position: relative;
    overflow: hidden;
    padding: clamp(72px, 10vw, 120px) 0;
    background:
      radial-gradient(120% 120% at 50% -10%, rgba(81, 9, 10, 0.85), transparent 60%),
      var(--color-primary-dark);
    color: var(--color-white);
    text-align: center;
  }
  .premium__glow {
    position: absolute;
    top: -30%;
    left: 50%;
    transform: translateX(-50%);
    width: 760px;
    height: 760px;
    background: radial-gradient(circle, rgba(184, 135, 83, 0.16), transparent 62%);
    pointer-events: none;
  }
  .premium__mono {
    position: absolute;
    right: 4%;
    bottom: -16%;
    font-family: var(--font-title);
    font-size: clamp(20rem, 34vw, 38rem);
    line-height: 1;
    color: rgba(184, 135, 83, 0.07);
    pointer-events: none;
    user-select: none;
  }
  .premium__inner {
    position: relative;
    z-index: 2;
    max-width: 720px;
  }
  .premium .kicker {
    color: var(--color-gold-soft);
  }
  .premium h2 {
    margin-top: 22px;
    color: var(--color-white);
    font-size: clamp(2.4rem, 4.4vw, 4rem);
  }
  .premium p {
    margin: 22px auto 0;
    max-width: 560px;
    color: rgba(255, 255, 255, 0.74);
    font-size: 1.12rem;
  }
  .premium__actions {
    margin-top: 40px;
    display: flex;
    gap: 18px;
    justify-content: center;
    flex-wrap: wrap;
  }
</style>
