---
import { content } from "../data/content.ts";
import PhotoFrame from "./PhotoFrame.astro";
import draPhoto from "../assets/dra-gabriela-2.webp";
const { about, doctor } = content;
---

<section id="sobre" class="section section-light about">
  <div class="container about__grid">
    <div class="about__media" data-reveal="left">
      <PhotoFrame ratio="4 / 5" tone="nude" image={draPhoto} alt="Dra. Gabriela Dornelas, ginecologista e obstetra" position="center 12%" />
      <div class="about__crm" data-reveal="scale" data-reveal-delay="2">
        <span>{doctor.crm}</span>
        <span class="about__crm-sep"></span>
        <span>{doctor.rqe}</span>
      </div>
    </div>

    <div class="about__content">
      <span class="kicker" data-reveal>{about.kicker}</span>
      <h2 data-reveal data-reveal-delay="1">{about.title}</h2>

      <div class="about__paras">
        {about.paragraphs.map((p, i) => (
          <p class={i === 0 ? "text-large" : ""} data-reveal data-reveal-delay={i + 1}>{p}</p>
        ))}
      </div>

      <ul class="about__creds" data-reveal>
        {about.credentials.map((c) => (
          <li>{c}</li>
        ))}
      </ul>

      <div class="about__footer" data-reveal>
        <span class="about__signature">{about.signature}</span>
        <a class="btn btn-primary" href={doctor.whatsappUrl} target="_blank" rel="noopener">
          {about.ctaLabel}
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .about__grid {
    display: grid;
    grid-template-columns: minmax(0, 0.82fr) minmax(0, 1.18fr);
    gap: 72px;
    align-items: center;
  }
  .about__media {
    position: relative;
    max-width: 400px;
  }
  .about__crm {
    position: absolute;
    left: 50%;
    bottom: -22px;
    transform: translateX(-50%);
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 14px 26px;
    background: var(--color-white);
    border: 1px solid rgba(184, 135, 83, 0.3);
    border-radius: var(--radius-pill);
    box-shadow: var(--shadow-soft);
    font-family: var(--font-logo);
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    color: var(--color-primary);
    white-space: nowrap;
  }
  .about__crm-sep {
    width: 1px;
    height: 14px;
    background: rgba(81, 9, 10, 0.24);
  }

  .about__content h2 {
    margin-top: 20px;
    max-width: 18ch;
  }
  .about__paras {
    margin-top: 26px;
    display: flex;
    flex-direction: column;
    gap: 18px;
  }
  .about__creds {
    list-style: none;
    margin: 32px 0 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
  }
  .about__creds li {
    font-family: var(--font-body);
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    color: var(--color-brown);
    padding: 9px 18px;
    border: 1px solid rgba(184, 135, 83, 0.34);
    border-radius: var(--radius-pill);
    background: rgba(247, 242, 238, 0.6);
  }
  .about__footer {
    margin-top: 36px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 28px;
    flex-wrap: wrap;
  }
  .about__signature {
    font-family: var(--font-title);
    font-style: italic;
    font-size: 2rem;
    color: var(--color-primary);
  }

  @media (max-width: 920px) {
    .about__grid {
      grid-template-columns: 1fr;
      gap: 56px;
    }
    .about__media {
      max-width: 340px;
      margin: 0 auto;
    }
  }
</style>
